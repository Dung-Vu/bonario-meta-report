# Server Port Configuration
BONARIO_PORT=3001

# Secret token used by write endpoints (refresh). Send this in 'x-bonario-secret' header.
BONARIO_REFRESH_SECRET=your_production_refresh_secret_here

# Meta Ads API Credentials
META_ACCESS_TOKEN=your_meta_access_token_here
META_AD_ACCOUNT_ID=act_your_ad_account_id_here
META_API_VERSION=v22.0

# Odoo CRM API Credentials
ODOO_URL=https://bonario-vietnam.odoo.com
ODOO_DB=bonario-vietnam
ODOO_USER_ID=your_odoo_user_id_here
ODOO_API_KEY=your_odoo_api_key_here


